# Normalize line endings: Git stores text files with LF in the repository.
* text=auto eol=lf

# Explicitly treat these as text with LF endings.
*.md       text eol=lf
*.toml     text eol=lf
*.json     text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.txt      text eol=lf
*.sh       text eol=lf
*.ps1      text eol=crlf
LICENSE    text eol=lf

# Binary assets: never modify.
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.webp     binary
*.svg      text eol=lf
*.ico      binary
*.pdf      binary
